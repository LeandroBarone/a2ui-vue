{
  "name": "a2ui-vue",
  "version": "0.1.0",
  "description": "Vue 3 renderer for the A2UI (Agent-to-User Interface) protocol v0.8",
  "license": "Apache-2.0",
  "homepage": "https://github.com/LeandroBarone/a2ui-vue#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeandroBarone/a2ui-vue.git"
  },
  "keywords": [
    "a2ui",
    "vue",
    "vue3",
    "agent",
    "ui",
    "renderer",
    "a2a",
    "jsonl"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/v0_8/public-api.d.ts",
  "exports": {
    ".": {
      "types": "./dist/v0_8/public-api.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "demo": "vite --config demo/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "tsc:check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@a2ui/web_core": "^0.9.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@a2ui/web_core": "^0.9.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.17",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^27.2.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.3.0",
    "vitest": "^4.0.15",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  },
  "sideEffects": false
}
